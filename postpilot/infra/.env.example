# Copy this file to infra/.env on the VPS and replace every CHANGE_ME value.
# Keep the file mode at 0600. Never commit infra/.env.

# Public hostnames (API_DOMAIN has no scheme or path)
API_DOMAIN=api.example.com
# Only used by the optional self-hosted web profile.
APP_DOMAIN=app.example.com
# For the optional self-hosted cockpit only, uncomment this after its setup:
# COMPOSE_PROFILES=self-host-web
ACME_EMAIL=admin@example.com
OAUTH_REDIRECT_BASE=https://api.example.com
COCKPIT_URL=https://app.example.com
CORS_ALLOWED_ORIGINS=https://app.example.com,http://localhost:3000

# PostgreSQL. DB_PASS can be generated with scripts/generate-secrets.*
DB_NAME=postpilot
DB_USER=postpilot
DB_PASS=CHANGE_ME_RANDOM_HEX
DB_POOL_SIZE=10

# The web app and engine must contain the exact same value.
COCKPIT_JWT_SECRET=CHANGE_ME_RANDOM_BASE64

# Exactly 32 random bytes encoded as Base64. Losing this key makes stored OAuth
# tokens unreadable. Rotating it requires a planned token migration/reconnect.
VAULT_KEY=CHANGE_ME_32_BYTE_BASE64

# Cloudflare R2 media bucket. Use a bucket-scoped Object Read & Write token.
R2_ACCOUNT_ID=CHANGE_ME
R2_ACCESS_KEY_ID=CHANGE_ME
R2_SECRET_ACCESS_KEY=CHANGE_ME
R2_BUCKET=postpilot-media
R2_PUBLIC_BASE_URL=https://media.example.com
R2_PRESIGN_TTL=15m
# v1 publishers buffer an object in Java heap. Keep upload and publisher caps
# aligned at 25 MiB until those adapters use true streaming uploads.
R2_MAX_UPLOAD_BYTES=26214400
PUBLISH_MAX_IN_MEMORY_MEDIA_BYTES=26214400

# Optional notifications. Leave both blank to disable Telegram.
TG_BOT_TOKEN=
TG_CHAT_ID=

# Meta app (Facebook Pages + Instagram Professional via Facebook Login)
META_CLIENT_ID=
META_CLIENT_SECRET=
META_API_VERSION=v25.0

# LinkedIn app (the self-service Share on LinkedIn product posts to a member)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_API_VERSION=202601

# X app. X API access currently requires prepaid pay-per-use credits.
X_CLIENT_ID=
X_CLIENT_SECRET=
X_API_VERSION=2

# Publishing behavior
PUBLISH_MAX_ATTEMPTS=3
PUBLISH_HTTP_TIMEOUT=60s

# Private R2 backup bucket. Create a separate bucket-scoped token so the public
# media credential cannot read or delete backups.
BACKUP_R2_ACCOUNT_ID=CHANGE_ME
BACKUP_R2_ACCESS_KEY_ID=CHANGE_ME
BACKUP_R2_SECRET_ACCESS_KEY=CHANGE_ME
BACKUP_R2_BUCKET=postpilot-backups
RESTIC_PASSWORD=CHANGE_ME_LONG_RANDOM_BASE64
