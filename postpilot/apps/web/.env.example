# The Spring engine's API root. Keep credentials server-side; never prefix them NEXT_PUBLIC_.
ENGINE_URL=http://localhost:8080/api/v1

# The proxy signs a short-lived bearer JWT with this engine-shared secret.
COCKPIT_JWT_SECRET=replace-with-the-same-strong-secret-used-by-the-engine

# Single cockpit administrator.
ADMIN_EMAIL=admin@example.com
# Base64 avoids `$` interpolation problems in local .env and Docker Compose.
# Generate both forms with `npm run hash -- 'your password'`; prefer base64 here.
ADMIN_PASSWORD_HASH_BASE64=replace_with_base64_hash_output
# ADMIN_PASSWORD_HASH='$2b$12$keep_bcrypt_hash_inside_single_quotes'

# At least 32 random bytes. `openssl rand -base64 48` is suitable.
NEXTAUTH_SECRET=replace-with-a-long-random-secret

# Cookies are secure automatically outside development. Set only when you need
# an explicit local override; production must use HTTPS/true.
# AUTH_COOKIE_SECURE=false
# AUTH_SESSION_HOURS=12

# Optional read-only UI preview. Demo mode returns fixtures and blocks every write.
# DEMO_MODE=true

# Keep this equal to the engine/infra upload limit (25 MiB by default).
# NEXT_PUBLIC_MAX_UPLOAD_BYTES=26214400

# Optional client-side CSV check. Set to the hostname from R2_PUBLIC_BASE_URL.
# NEXT_PUBLIC_R2_MEDIA_HOST=media.example.com



